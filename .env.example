# =========================
# Example template (copy to .env or .env.staging)
# =========================

# --- App core ---
APP_ENV=staging
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
BASE_URL=https://staging.sokolrock.org
RUN_BOT=true

# --- Telegram bot ---
BOT_TOKEN=replace_me
ADMIN_TELEGRAM_IDS=111111111,222222222
BOT_RATE_LIMIT_PER_MINUTE=30

# --- Database ---
DATABASE_URL=postgresql+psycopg://vpnbot:vpnbot@postgres:5432/vpnbot

# --- Webhook/security ---
WEBHOOK_SHARED_SECRET=replace_me_webhook_secret
YOO_KASSA_WEBHOOK_IP_ALLOWLIST=

# --- S-UI integration ---
SUI_IMAGE=ghcr.io/alireza0/s-ui:latest
SUI_PANEL_BASE_PATH=/app
SUI_DEFAULT_PATH_PREFIX=/sub/
SUI_REQUEST_TIMEOUT=15
SUI_API_TOKEN=replace_me
# One subscription for HY2 + VLESS
# Example: SUI_INBOUND_IDS=10,11
SUI_INBOUND_IDS=

# --- YooKassa (currently disabled in code) ---
YOO_KASSA_SHOP_ID=replace_me
YOO_KASSA_SECRET_KEY=replace_me
YOO_KASSA_TEST_MODE=true
YOO_KASSA_RETURN_URL=https://staging.sokolrock.org/payment/return

# --- CryptoBot payments (active) ---
CRYPTO_PROVIDER=cryptobot
CRYPTO_TEST_MODE=true
CRYPTO_DEFAULT_RATE_RUB=95.0
CRYPTO_BOT_TOKEN=replace_me
CRYPTO_BOT_API_BASE=https://pay.crypt.bot/api

# --- Trial/plans ---
TRIAL_DAYS=3
TRIAL_GRACE_DAYS=1
PLAN_MONTH_PRICE_RUB=100
PLAN_YEAR_PRICE_RUB=1000
SUBSCRIPTION_EXPIRY_NOTIFY_HOURS=24

# --- Postgres container vars ---
POSTGRES_DB=vpnbot
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=vpnbot

# --- Domains ---
DOMAIN_PROD=sokolrock.org
DOMAIN_STAGING=staging.sokolrock.org
